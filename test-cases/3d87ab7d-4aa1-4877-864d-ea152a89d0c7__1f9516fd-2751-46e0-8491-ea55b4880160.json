{
  "id": "1f9516fd-2751-46e0-8491-ea55b4880160",
  "testPlanId": "3d87ab7d-4aa1-4877-864d-ea152a89d0c7",
  "requirementId": "91acd319-cc6b-4b76-9518-b8babe4b3aa3",
  "suiteName": "Certinia PSA - Start Planned Project Task (Salesforce Lightning)",
  "case": {
    "id": "1f9516fd-2751-46e0-8491-ea55b4880160",
    "title": "Start a Planned Project Task and verify updates (Status, Started checkbox, Actual Start Date)",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Open Salesforce Lightning Home",
        "value": "https://ukgsf--stest.sandbox.lightning.force.com/lightning/page/home"
      },
      {
        "id": "s2",
        "action": "tap",
        "targetDescription": "Navigate end-to-end to a Planned Project Task detail page (login/search/navigation encapsulated)",
        "screenName": "CommonFlowsPage",
        "pageObjectMethod": "userJourneyTillProjectTask"
      },
      {
        "id": "step10",
        "action": "tap",
        "targetDescription": "Select row having planned status",
        "customCode": "await page.locator('tr:has(td:has-text(\"Planned\")) th[data-label=\"Project Task Name\"]').nth(1).click();"
      },
      {
        "id": "step11",
        "action": "tap",
        "targetDescription": "Wait for start button to be visible",
        "screenName": "ProjectTaskDetail",
        "pageObjectMethod": "expectStartVisible"
      },
      {
        "id": "s6",
        "action": "tap",
        "targetDescription": "Click Start button",
        "screenName": "ProjectTaskDetailPage",
        "pageObjectMethod": "clickStart"
      },
      {
        "id": "s7",
        "action": "wait",
        "targetDescription": "Wait for task to update",
        "value": "1500"
      },
      {
        "id": "s8",
        "action": "assertHidden",
        "targetDescription": "Verify Planned status text no longer visible",
        "screenName": "ProjectTaskDetailPage",
        "pageObjectMethod": "expectPlannedHidden"
      },
      {
        "id": "s9",
        "action": "assertHidden",
        "targetDescription": "Verify Start button is no longer visible after starting",
        "screenName": "ProjectTaskDetailPage",
        "pageObjectMethod": "expectStartHidden"
      },
      {
        "id": "s10",
        "action": "assertChecked",
        "targetDescription": "Verify 'Started' checkbox is checked",
        "locatorHint": "[role=\"checkbox\"][aria-label=\"Started\"]"
      },
      {
        "id": "s11",
        "action": "assertContainsText",
        "targetDescription": "Verify Status field value is 'Started'",
        "locatorHint": "records-record-layout-item:has(.slds-form-element__label:has-text(\"Status\")) .slds-form-element__control",
        "assertion": "Started"
      },
      {
        "id": "s12",
        "action": "assertContainsText",
        "targetDescription": "Verify Actual Start Date populated with current date",
        "locatorHint": "records-record-layout-item:has(.slds-form-element__label:has-text(\"Actual Start Date\")) lightning-formatted-date-time, records-record-layout-item:has(.slds-form-element__label:has-text(\"Actual Start Date\")) .slds-form-element__control",
        "assertion": "{{CURRENT_DATE}}"
      }
    ],
    "tags": [
      "@e2e",
      "@regression"
    ]
  }
}
