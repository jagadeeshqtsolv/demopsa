            "screenName": "ProjectTaskDetail",
            "pageObjectMethod": "expectProjectNameVisible",
            "customCode": "await expect(page.getByRole('link', { name: \"Perry's Restaurants, - Q-\" })).toBeVisible();"
          },
          {
            "id": "s13",
            "action": "assertVisible",
            "targetDescription": "Verify Status = Planned is shown",
            "screenName": "ProjectTaskDetailPage",
            "pageObjectMethod": "expectPlannedVisible"
          },
          {
            "id": "s14",
            "action": "assertVisible",
